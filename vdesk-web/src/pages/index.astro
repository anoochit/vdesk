---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import Officer from '../components/Officer.astro';
import { agents } from '../config/agents';

// Map is 40x23 tiles, each tile is 32x32 pixels.
// That is 1280x736 pixels. 
// 4 Rooms: 3 Offices, 1 Living Room (Top Right)
const START_POSITIONS = [
	{ x: 4 * 32 + 16, y: 3.2 * 32 + 32 },   // Office 1 - First desk chair (Dev)
	{ x: 4 * 32 + 16, y: 15.2 * 32 + 32 },  // Office 2 - First desk chair (Ops)
	{ x: 32 * 32 + 16, y: 17.2 * 32 + 32 }, // Office 3 - Manager Room Chair
];

function getPos(i: number) {
	return START_POSITIONS[i % START_POSITIONS.length];
}
---
<Layout title="16-bit Virtual Agent Office">
	<main>
		<section class="office-wrapper">
			<Map>
				{agents.map((agent, i) => {
					const { x, y } = getPos(i);
					return (
						<Officer
							agentId={agent.agentId}
							name={agent.name}
							sprite={agent.sprite}
							initialX={x}
							initialY={y}
						/>
					);
				})}
			</Map>
		</section>
	</main>
</Layout>

<style>
	main {
		display: flex;
		flex-direction: column;
		height: 100vh;
		width: 100vw;
		background-color: #212529;
		overflow: auto; /* Allow scrolling if map is bigger than window */
		padding: 2rem;
		box-sizing: border-box;
	}

	.office-wrapper {
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
	}
</style>

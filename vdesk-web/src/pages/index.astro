---
import Layout from '../layouts/Layout.astro';
import Officer from '../components/Officer.astro';
import { agents } from '../config/agents';

// Auto-layout: arrange agents in a grid based on count
const DESK_W = 80;
const DESK_H = 40;
const COL_GAP = 200;
const ROW_GAP = 200;
const OFFSET_X = 100;
const OFFSET_Y = 150;
const COLS = Math.ceil(Math.sqrt(30));

function getPos(i: number) {
	const col = i % COLS;
	const row = Math.floor(i / COLS);
	return {
		x: OFFSET_X + col * COL_GAP,
		y: OFFSET_Y + row * ROW_GAP,
	};
}
---
<Layout title="16-bit Virtual Agent Office">
	<main>
		<!-- <header class="office-header">
			<h1 class="nes-text is-primary">VIRTUAL OFFICE v1.0</h1>
			<p class="nes-text is-disabled">Real-time ADK Agent Monitor</p>
		</header> -->

		<section class="office-floor">
			<div class="pixel-grid"></div>

			{agents.map((agent, i) => {
				const { x, y } = getPos(i);
				return (
					<>
						<div class="desk" style={`left: ${x}px; top: ${y}px;`}></div>
						<Officer
							agentId={agent.agentId}
							name={agent.name}
							x={x-20}
							y={y - 60}
							initialEmoji={agent.initialEmoji}
						/>
					</>
				);
			})}
		</section>

		<!-- <footer class="office-footer">
			<div class="nes-container is-dark with-title">
				<p class="title">System Logs</p>
				<p id="system-status">Broker: Connected to emqx.io</p>
			</div>
		</footer> -->
	</main>
</Layout>

<style>
	main {
		display: flex;
		flex-direction: column;
		height: 100vh;
		padding: 2rem;
	}

	.office-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.office-floor {
		flex: 1;
		position: relative;
		border: 4px solid #fff;
		background-color: #333;
		overflow: hidden;
	}

	.pixel-grid {
		position: absolute;
		width: 100%;
		height: 100%;
		background-image: 
			linear-gradient(to right, #444 1px, transparent 1px),
			linear-gradient(to bottom, #444 1px, transparent 1px);
		background-size: 40px 40px;
		opacity: 0.3;
	}

	.desk {
		position: absolute;
		width: 80px;
		height: 40px;
		background-color: #8b4513;
		border: 4px solid #000;
		box-shadow: 4px 4px 0px #5d2e0d;
	}

	.office-footer {
		margin-top: 2rem;
		height: 100px;
	}

	h1 { font-size: 1.5rem; }
	p { font-size: 0.7rem; }
</style>